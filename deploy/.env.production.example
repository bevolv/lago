LAGO_DOMAIN=
LAGO_ACME_EMAIL=
SECRET_KEY_BASE=
LAGO_ENCRYPTION_PRIMARY_KEY=
LAGO_ENCRYPTION_DETERMINISTIC_KEY=
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=

POSTGRES_USER=lago
POSTGRES_PASSWORD=
POSTGRES_DB=lago
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Optional: set to true when using external managed DB and Redis and run with --profile all-no-db
# LAGO_USE_EXTERNAL_DB=true

# Optional: enable only when starting with --profile portainer
PORTAINER_USER=
PORTAINER_PASSWORD=

# Optional: Dozzle log viewer, always deployed at https://<DOZZLE_HOSTNAME>.bevolv.co
# (defaults to dozzle.lago.bevolv.co if unset).
DOZZLE_HOSTNAME=

# Dozzle is protected by Traefik basic auth read from ./htpasswd/dozzle (not an env
# var — compose can't hash a password at runtime). Generate that file manually before
# starting the stack:
#   mkdir -p htpasswd
#   echo "admin:$(openssl passwd -apr1 'your-password')" > htpasswd/dozzle